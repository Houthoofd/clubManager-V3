# ============================================================
# CLUBMANAGER V3 - CONFIGURATION ENVIRONMENT
# ============================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ============================================================

# ------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------
NODE_ENV=development
PORT=3000
API_VERSION=v3
APP_NAME=ClubManager
APP_URL=http://localhost:3000

# ------------------------------------------------------------
# DATABASE (MySQL)
# ------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=clubmanager
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# Database SSL (production)
DB_SSL_ENABLED=false
DB_SSL_CA_PATH=
DB_SSL_CERT_PATH=
DB_SSL_KEY_PATH=

# ------------------------------------------------------------
# AUTHENTICATION & SECURITY
# ------------------------------------------------------------

# JWT Access Token (expires quickly, e.g., 15 minutes)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_minimum_32_characters
JWT_EXPIRES_IN=15m

# JWT Refresh Token (long-lived, e.g., 7 days)
JWT_REFRESH_SECRET=your_refresh_token_secret_key_change_this_minimum_32_characters
JWT_REFRESH_EXPIRES_IN=7d

# Password Hashing
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGIN=http://localhost:3001
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cookie Security
COOKIE_SECRET=your_cookie_secret_key_minimum_32_characters
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=lax

# ------------------------------------------------------------
# EMAIL SERVICE (SendGrid)
# ------------------------------------------------------------
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@clubmanager.com
SENDGRID_FROM_NAME=ClubManager

# Email Templates
EMAIL_VERIFICATION_URL=http://localhost:3001/verify-email
PASSWORD_RESET_URL=http://localhost:3001/reset-password

# ------------------------------------------------------------
# STRIPE PAYMENT GATEWAY
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_API_VERSION=2024-03-25

# Stripe URLs
STRIPE_SUCCESS_URL=http://localhost:3001/payment/success
STRIPE_CANCEL_URL=http://localhost:3001/payment/cancel

# ------------------------------------------------------------
# AWS S3 (File Storage)
# ------------------------------------------------------------
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET_NAME=clubmanager-files

# S3 Folders
S3_PHOTOS_FOLDER=photos
S3_DOCUMENTS_FOLDER=documents
S3_ARTICLES_FOLDER=articles

# File Upload Limits
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=7d
LOG_DATE_PATTERN=YYYY-MM-DD

# ------------------------------------------------------------
# FRONTEND URL
# ------------------------------------------------------------
FRONTEND_URL=http://localhost:3001
CLIENT_URL=http://localhost:3001

# ------------------------------------------------------------
# TESTING (used when NODE_ENV=test)
# ------------------------------------------------------------
TEST_DB_HOST=localhost
TEST_DB_PORT=3306
TEST_DB_USER=root
TEST_DB_PASSWORD=test_password
TEST_DB_NAME=clubmanager_test

# ------------------------------------------------------------
# OPTIONAL SERVICES
# ------------------------------------------------------------

# WebSocket
WEBSOCKET_ENABLED=true
WEBSOCKET_PORT=3001

# Redis (for sessions/cache - optional)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Monitoring & Analytics
SENTRY_DSN=
GOOGLE_ANALYTICS_ID=

# ------------------------------------------------------------
# DEVELOPMENT & DEBUG
# ------------------------------------------------------------
DEBUG=clubmanager:*
ENABLE_MORGAN_LOGS=true
ENABLE_SQL_LOGS=false
ENABLE_CORS_LOGS=false

# ------------------------------------------------------------
# PRODUCTION SETTINGS
# ------------------------------------------------------------
# Uncomment and set these in production

# FORCE_HTTPS=true
# TRUST_PROXY=true
# SESSION_SECRET=your_production_session_secret_minimum_64_characters
# HELMET_ENABLED=true
# COMPRESSION_ENABLED=true
