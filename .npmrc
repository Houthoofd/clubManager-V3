# pnpm configuration

# Strict mode - recommandé pour éviter les "phantom dependencies"
shamefully-hoist=false

# Auto-install peer dependencies
auto-install-peers=true

# Strict peer dependencies (false pour éviter erreurs avec certains packages)
strict-peer-dependencies=false

# Use workspace protocol in package.json
save-workspace-protocol=true

# Lockfile settings
lockfile=true

# Node linker (isolated mode pour sécurité)
node-linker=isolated

# Store location (optionnel - décommenter si besoin)
# store-dir=~/.pnpm-store

# Enable pnpm to use git-hosted packages
enable-pre-post-scripts=true
