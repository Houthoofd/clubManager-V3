{
  "name": "@clubmanager/frontend",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "// ============================================================================": "",
    "// DEVELOPMENT": "",
    "// ============================================================================": "",
    "dev": "vite",
    "dev:host": "vite --host",
    "dev:https": "vite --https",
    "dev:debug": "NODE_OPTIONS='--inspect' vite",

    "// ============================================================================": "",
    "// BUILD": "",
    "// ============================================================================": "",
    "build": "tsc && vite build",
    "build:staging": "tsc && vite build --mode staging",
    "build:analyze": "ANALYZE=true npm run build",
    "build:report": "npm run build && npm run analyze:bundle",
    "build:clean": "rimraf dist && npm run build",

    "// ============================================================================": "",
    "// PREVIEW": "",
    "// ============================================================================": "",
    "preview": "vite preview",
    "preview:host": "vite preview --host",
    "preview:prod": "npm run build && vite preview",

    "// ============================================================================": "",
    "// TESTING": "",
    "// ============================================================================": "",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",

    "// ============================================================================": "",
    "// LINTING & FORMATTING": "",
    "// ============================================================================": "",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\"",
    "type-check": "tsc --noEmit",

    "// ============================================================================": "",
    "// ANALYSIS & OPTIMIZATION": "",
    "// ============================================================================": "",
    "analyze:bundle": "node ../docs/optimization-examples/analyze-bundle.js",
    "analyze:deps": "npx depcheck",
    "analyze:size": "npx bundlesize",
    "analyze:duplicates": "npx jscpd src",
    "analyze:unused": "npx unimported",
    "visualize": "npx vite-bundle-visualizer",

    "// ============================================================================": "",
    "// PERFORMANCE": "",
    "// ============================================================================": "",
    "perf:lighthouse": "npx lighthouse http://localhost:4173 --view",
    "perf:lighthouse-ci": "npx @lhci/cli autorun",
    "perf:bundle": "npm run build && npm run analyze:bundle",
    "perf:webvitals": "npm run preview && open http://localhost:4173",

    "// ============================================================================": "",
    "// DEPENDENCIES": "",
    "// ============================================================================": "",
    "deps:check": "npx npm-check-updates",
    "deps:update": "npx npm-check-updates -u && npm install",
    "deps:audit": "npm audit",
    "deps:audit-fix": "npm audit fix",
    "deps:clean": "rimraf node_modules package-lock.json && npm install",

    "// ============================================================================": "",
    "// IMAGES": "",
    "// ============================================================================": "",
    "images:optimize": "npx @squoosh/cli --webp auto src/assets/**/*.{jpg,png}",
    "images:convert-webp": "npx @squoosh/cli --webp {quality:80} src/assets/**/*.{jpg,png}",
    "images:convert-avif": "npx @squoosh/cli --avif {quality:70} src/assets/**/*.{jpg,png}",
    "images:svg-optimize": "npx svgo -f src/assets/icons -o src/assets/icons",

    "// ============================================================================": "",
    "// PWA": "",
    "// ============================================================================": "",
    "pwa:generate-icons": "npx pwa-asset-generator public/logo.svg public/icons",
    "pwa:test-sw": "npx workbox-cli wizard",

    "// ============================================================================": "",
    "// DATABASE & BACKEND": "",
    "// ============================================================================": "",
    "db:generate": "cd ../packages/types && npm run generate",
    "db:migrate": "cd ../../backend && npm run migrate",
    "db:seed": "cd ../../backend && npm run seed",

    "// ============================================================================": "",
    "// UTILITIES": "",
    "// ============================================================================": "",
    "clean": "rimraf dist .vite coverage node_modules/.vite",
    "clean:all": "rimraf dist .vite coverage node_modules",
    "postinstall": "echo '✅ Dependencies installed'",
    "validate": "npm run type-check && npm run lint && npm run test:run",
    "prepare": "cd ../.. && husky install frontend/.husky",

    "// ============================================================================": "",
    "// CI/CD": "",
    "// ============================================================================": "",
    "ci:install": "npm ci",
    "ci:build": "npm run type-check && npm run lint && npm run build",
    "ci:test": "npm run test:run -- --coverage",
    "ci:deploy": "echo 'Deploy script - configure according to your hosting'",

    "// ============================================================================": "",
    "// MONITORING": "",
    "// ============================================================================": "",
    "monitor:sentry": "npx @sentry/cli sourcemaps upload --validate dist",
    "monitor:bundle-size": "npx bundlewatch",

    "// ============================================================================": "",
    "// DOCUMENTATION": "",
    "// ============================================================================": "",
    "docs:serve": "npx http-server ../docs -p 8080 -o",
    "docs:optimize": "cat ../docs/FRONTEND_OPTIMIZATION_GUIDE.md",

    "// ============================================================================": "",
    "// COMBINED TASKS": "",
    "// ============================================================================": "",
    "full-check": "npm run type-check && npm run lint && npm run test:run && npm run build",
    "quick-check": "npm run type-check && npm run lint",
    "optimize": "npm run build:analyze && npm run analyze:deps && npm run perf:lighthouse",
    "fresh-start": "npm run clean:all && npm install && npm run dev",

    "// ============================================================================": "",
    "// NOTES": "",
    "// Scripts marked with // are comments for organization": "",
    "// Use 'npm run' to see all available scripts": "",
    "// Common workflows:": "",
    "//   - Development: npm run dev": "",
    "//   - Build & Analyze: npm run build:report": "",
    "//   - Full validation: npm run full-check": "",
    "//   - Optimize images: npm run images:optimize": "",
    "//   - Update deps: npm run deps:update": ""
  },
  "devDependencies": {
    "@lhci/cli": "^0.13.0",
    "@squoosh/cli": "^0.7.3",
    "@tailwindcss/forms": "^0.5.11",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react-swc": "^3.6.0",
    "@vitest/coverage-v8": "^1.3.1",
    "@vitest/ui": "^1.3.1",
    "autoprefixer": "^10.4.27",
    "bundlesize": "^0.18.1",
    "bundlewatch": "^0.3.3",
    "depcheck": "^1.4.7",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^24.0.0",
    "jscpd": "^4.0.5",
    "msw": "^2.2.1",
    "postcss": "^8.5.8",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "rollup-plugin-visualizer": "^5.12.0",
    "svgo": "^3.2.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.4.2",
    "unimported": "^1.31.1",
    "vite": "^5.1.5",
    "vite-bundle-visualizer": "^1.0.1",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-image-optimizer": "^1.1.7",
    "vite-plugin-pwa": "^0.19.0",
    "vitest": "^1.3.1"
  },
  "bundlesize": [
    {
      "path": "./dist/assets/*.js",
      "maxSize": "300 KB",
      "compression": "gzip"
    },
    {
      "path": "./dist/assets/*.css",
      "maxSize": "50 KB",
      "compression": "gzip"
    }
  ],
  "bundlewatch": {
    "files": [
      {
        "path": "./dist/assets/*.js",
        "maxSize": "300kb"
      },
      {
        "path": "./dist/assets/*.css",
        "maxSize": "50kb"
      }
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
