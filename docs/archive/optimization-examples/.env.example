# ============================================================================
# ClubManager V3 - Environment Variables (Optimized Build)
# ============================================================================
#
# Ce fichier contient toutes les variables d'environnement nécessaires
# pour les optimisations front-end.
#
# Instructions:
#   1. Copier ce fichier: cp .env.example .env
#   2. Remplir les valeurs appropriées
#   3. Ne JAMAIS commiter le fichier .env (il est dans .gitignore)
#
# ============================================================================

# ----------------------------------------------------------------------------
# APPLICATION
# ----------------------------------------------------------------------------

# Version de l'application (auto-généré depuis package.json si absent)
VITE_APP_VERSION=3.0.0

# Nom de l'application
VITE_APP_NAME=ClubManager

# Environment: development | staging | production
NODE_ENV=production

# ----------------------------------------------------------------------------
# API CONFIGURATION
# ----------------------------------------------------------------------------

# URL de base de l'API backend
VITE_API_BASE_URL=https://api.clubmanager.com

# URL de l'API en développement (utilisé avec proxy Vite)
VITE_API_URL=http://localhost:3000

# Timeout des requêtes API (ms)
VITE_API_TIMEOUT=30000

# ----------------------------------------------------------------------------
# CDN & ASSETS
# ----------------------------------------------------------------------------

# URL du CDN pour les assets statiques (optionnel)
# Si défini, tous les assets seront servis depuis ce CDN
VITE_CDN_URL=https://cdn.clubmanager.com

# URL pour les images Cloudflare Images (optionnel)
VITE_CLOUDFLARE_IMAGES_URL=https://clubmanager.com/cdn-cgi/image

# URL pour les assets uploadés par les utilisateurs
VITE_UPLOADS_URL=https://uploads.clubmanager.com

# ----------------------------------------------------------------------------
# MONITORING & ANALYTICS
# ----------------------------------------------------------------------------

# Sentry DSN pour error tracking
# Obtenir sur: https://sentry.io/settings/projects/
VITE_SENTRY_DSN=https://xxxxxxxxxxxxx@sentry.io/1234567

# Sentry environment
VITE_SENTRY_ENVIRONMENT=production

# Sentry traces sample rate (0.0 à 1.0)
# 0.2 = 20% des transactions sont trackées
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2

# Google Analytics 4 Measurement ID
# Format: G-XXXXXXXXXX
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Tag Manager ID (optionnel)
# Format: GTM-XXXXXXX
VITE_GTM_ID=GTM-XXXXXXX

# LogRocket App ID (optionnel)
VITE_LOGROCKET_APP_ID=xxxxx/clubmanager

# Hotjar Site ID (optionnel)
VITE_HOTJAR_SITE_ID=1234567

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------

# Activer les DevTools React Query en production
VITE_ENABLE_QUERY_DEVTOOLS=false

# Activer les logs de debug
VITE_ENABLE_DEBUG_LOGS=false

# Activer le mode maintenance
VITE_MAINTENANCE_MODE=false

# Activer les Service Workers / PWA
VITE_ENABLE_PWA=true

# Activer le prefetching automatique
VITE_ENABLE_PREFETCH=true

# ----------------------------------------------------------------------------
# PERFORMANCE BUDGETS
# ----------------------------------------------------------------------------

# Seuil d'avertissement pour la taille des chunks (KB)
VITE_CHUNK_SIZE_WARNING=1000

# Bundle size maximum autorisé (KB)
VITE_MAX_BUNDLE_SIZE=800

# Temps maximum de chargement initial (ms)
VITE_MAX_INITIAL_LOAD_TIME=3000

# ----------------------------------------------------------------------------
# THIRD-PARTY SERVICES
# ----------------------------------------------------------------------------

# Stripe Publishable Key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# Stripe Account ID (pour Stripe Connect)
VITE_STRIPE_ACCOUNT_ID=acct_xxxxxxxxxxxxx

# MapBox Access Token (si cartes utilisées)
VITE_MAPBOX_ACCESS_TOKEN=pk.xxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------------------------
# PWA CONFIGURATION
# ----------------------------------------------------------------------------

# Nom de l'application PWA
VITE_PWA_NAME=ClubManager V3

# Nom court de l'application PWA (12 caractères max)
VITE_PWA_SHORT_NAME=ClubManager

# Description de l'application PWA
VITE_PWA_DESCRIPTION=Application de gestion de club sportif

# Couleur du thème PWA (hex)
VITE_PWA_THEME_COLOR=#2563eb

# Couleur de background PWA (hex)
VITE_PWA_BACKGROUND_COLOR=#ffffff

# ----------------------------------------------------------------------------
# BUILD OPTIMIZATION
# ----------------------------------------------------------------------------

# Activer la compression Brotli
VITE_ENABLE_BROTLI=true

# Activer la compression Gzip
VITE_ENABLE_GZIP=true

# Activer les source maps en production
# Options: true | false | hidden
VITE_SOURCEMAP=hidden

# Supprimer console.log en production
VITE_DROP_CONSOLE=true

# Activer le bundle analyzer
# npm run build avec ANALYZE=true pour visualiser
ANALYZE=false

# Niveau de minification
# Options: terser | esbuild | false
VITE_MINIFY=terser

# ----------------------------------------------------------------------------
# CACHE CONFIGURATION
# ----------------------------------------------------------------------------

# Durée de cache pour les assets statiques (secondes)
VITE_CACHE_MAX_AGE=31536000

# Durée de stale-while-revalidate (secondes)
VITE_CACHE_SWR_MAX_AGE=86400

# Nombre maximum d'entrées en cache API
VITE_CACHE_API_MAX_ENTRIES=100

# Durée de cache API (secondes)
VITE_CACHE_API_MAX_AGE=86400

# ----------------------------------------------------------------------------
# DEVELOPMENT
# ----------------------------------------------------------------------------

# Port du serveur de développement
VITE_DEV_PORT=5173

# Port du serveur de preview
VITE_PREVIEW_PORT=4173

# Ouvrir automatiquement le navigateur
VITE_OPEN_BROWSER=true

# Activer HTTPS en développement
VITE_HTTPS=false

# Host pour le serveur de dev (0.0.0.0 pour accès réseau)
VITE_HOST=localhost

# ----------------------------------------------------------------------------
# TESTING
# ----------------------------------------------------------------------------

# URL de base pour les tests E2E
VITE_TEST_BASE_URL=http://localhost:5173

# Activer les mocks MSW en développement
VITE_ENABLE_MSW=false

# ----------------------------------------------------------------------------
# LIGHTHOUSE CI
# ----------------------------------------------------------------------------

# Token GitHub pour Lighthouse CI
LHCI_GITHUB_APP_TOKEN=

# URL du serveur Lighthouse CI (si self-hosted)
LHCI_SERVER_BASE_URL=

# ----------------------------------------------------------------------------
# SECURITY
# ----------------------------------------------------------------------------

# Content Security Policy (CSP)
VITE_CSP_ENABLED=true

# Domaines autorisés pour CSP
VITE_CSP_ALLOWED_DOMAINS=clubmanager.com,*.cloudflare.com

# ----------------------------------------------------------------------------
# EXPERIMENTAL FEATURES
# ----------------------------------------------------------------------------

# Activer les React Server Components (expérimental)
VITE_ENABLE_RSC=false

# Activer le mode concurrent React
VITE_ENABLE_CONCURRENT_MODE=false

# Activer les optimisations expérimentales Vite
VITE_EXPERIMENTAL_OPTIMIZATIONS=false

# ----------------------------------------------------------------------------
# NOTES
# ----------------------------------------------------------------------------
#
# Variables obligatoires en production:
#   - VITE_API_BASE_URL
#   - VITE_SENTRY_DSN (recommandé)
#   - VITE_GA4_MEASUREMENT_ID (recommandé)
#
# Variables obligatoires si fonctionnalités utilisées:
#   - VITE_STRIPE_PUBLISHABLE_KEY (si paiements Stripe)
#   - VITE_CDN_URL (si CDN utilisé)
#
# Performance Tips:
#   - Activer VITE_ENABLE_BROTLI pour meilleure compression
#   - Définir VITE_SENTRY_TRACES_SAMPLE_RATE entre 0.1-0.3
#   - Activer VITE_ENABLE_PWA pour offline support
#   - Utiliser VITE_CDN_URL pour servir les assets
#
# ============================================================================
